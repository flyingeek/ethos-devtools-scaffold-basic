{
    "Lua.workspace.library": [
        "${addons}/ethos/module/library"
    ],
    "Lua.completion.callSnippet": "Replace",
    "Lua.completion.autoRequire": false,
    "Lua.runtime.version": "Lua 5.4",
    "Lua.runtime.builtin": {
        "bit": "disable",
        "bit32": "disable",
        "coroutine": "disable",
        "debug": "disable",
        "ffi": "disable",
        "jit": "disable"
    },
    "Lua.workspace.checkThirdParty": false,
    "ethos-devtools.deploy": {
        "app": "${{appPath}}",
        "manifest": "",
        "steps": [
            {
                "script": ".ethos-devtools/deploy-steps/deploy-model.mjs",
                "args": [".ethos-devtools/sim-model.bin"]
            },
            {
                "script": ".ethos-devtools/deploy-steps/deploy-sensors.mjs",
                "args": [".ethos-devtools/sensors.json"],
                "env": { "ETHOS_VERSION": "${config:ethos.release}" }
            }
        ]
    },
    "ethos.board": "X20PRO",
    "ethos.protocol": "FCC",
    "ethos.release": "nightly26"
}
